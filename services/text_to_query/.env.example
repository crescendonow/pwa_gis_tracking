# Text-to-Query Service Configuration

# Service
PORT=5022

# LLM Provider: "gemini" (recommended) or "ollama" (local, free)
LLM_PROVIDER=gemini
LLM_TIMEOUT=30

# Gemini Flash (get API key: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Ollama (fallback, local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=scb10x/typhoon2.1-gemma3-4b
OLLAMA_TIMEOUT=600

# PostgreSQL (PostGIS)
PG_HOST=192.168.242.38
PG_PORT=5432
PG_DB=pgweb_gis2
PG_USER=gispwadb
PG_PASS="gis#2016"
PG_SSLMODE=disable

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=vallaris_feature

# Cache
CACHE_TTL_HOURS=24
CACHE_MAX_ENTRIES=10000

# Rate Limit
RATE_LIMIT=10/minute
